--Generate PDF Button click dynamic action
--2nd True Action
declare
  l_blob blob;
begin
  select blob_content
  into l_blob
  from apex_application_temp_files
  where name = :P8_PROFILE;

  INSERT INTO USER_PROFILE_DETAILS (USER_NAME, USER_EMAIL, USER_PHONE_NUMBER, USER_PROFILE)
  VALUES (:P8_NAME, :P8_EMAIL_ID, :P8_PHONE_NUMBER, l_blob);

  commit;
end;
